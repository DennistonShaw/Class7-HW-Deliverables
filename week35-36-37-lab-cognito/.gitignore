# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform lock files
*.terraform.lock.hcl.*
.terraform.lock.hcl

# Ignore keys
*.pem

# Ignore packages / archives
*.rpm
rpm_packages/
*.zip

# macOS files
.DS_Store
**/.DS_Store
._.DS_Store
**/._.DS_Store

# Python virtual environments
venv/

# Local scratch files just something with sensitive data that should not be committed
scratch-pad.txt

# local-only token/curl output, never pushed to GitHub, safe to delete anytime
token-output-local.txt
*token-output*.txt

# draw.io backup/temp files
*.drawio.bkp
*.drawio.tmp
*.drawio.dtmp